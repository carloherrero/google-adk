# Copy this file to city_briefing_agent/.env and fill in real values.
# DO NOT commit the real .env file.

# ────────────────────────────────────────────────────────────────
# Model selection — pick ONE provider
# ────────────────────────────────────────────────────────────────
# Options:
#   gemini        — gemini-2.5-flash (cloud, free tier: 250 RPD)
#   gemini-lite   — gemini-2.5-flash-lite (cloud, free tier: 1000 RPD)
#   claude        — Anthropic Claude Haiku 4.5 (paid, ~$1/M tokens)
#   claude-sonnet — Anthropic Claude Sonnet 4.6 (paid, smarter)
#   ollama        — Local Qwen 2.5 7B (free, needs ~8GB RAM, modest GPU)
#   ollama-14b    — Local Qwen 2.5 14B (free, needs 16GB RAM/VRAM)
#   ollama-32b    — Local Qwen 2.5 32B (free, needs ~20GB VRAM)
LLM_PROVIDER=gemini

# ────────────────────────────────────────────────────────────────
# API keys — only the ones for your chosen provider are needed,
# but you can keep all three filled in so you can switch freely.
# ────────────────────────────────────────────────────────────────

# GEMINI

# Tells ADK to use the Gemini API directly (not Vertex AI / gcloud auth)
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Get from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_key_here

# Gemini model to use
GEMINI_MODEL=gemini-2.5-flash

# OLLAMA

# Required for LLM_PROVIDER=ollama* — no API key needed, but Ollama
# must be running locally on http://localhost:11434 (the default).
# Install from https://ollama.com, then: ollama pull qwen2.5:14b

# local ollama model to use
OLLAMA_MODEL=qwen2.5:7b

# ollama chat (use instead of ollama prompt for google adk as recommended in docs)
OLLAMA_HOST=http://localhost:11434
# used for liteLLM
OLLAMA_API_BASE=http://localhost:11434

# CLAUDE

# Required for LLM_PROVIDER=claude or claude-sonnet
# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_key_here


# ────────────────────────────────────────────────────────────────
# Tool API keys — always required (these power the actual data lookups)
# ────────────────────────────────────────────────────────────────

# Get from https://home.openweathermap.org/api_keys (free tier, no card)
OPENWEATHER_API_KEY=your_openweather_key_here

# Get from https://newsapi.org/register (free tier, no card)
NEWSAPI_KEY=your_newsapi_key_here




